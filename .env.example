# ============================================================================
# Tally configuration
# ----------------------------------------------------------------------------
# Tally runs in LOCAL mode with NO setup (data stays in the browser) so you can
# develop instantly. To go to a real backend, choose ONE of the options below,
# copy this file to ".env", fill it in, and restart.
# ============================================================================

# ---- Which backend to use -------------------------------------------------
# "local" (default) | "aws" | "supabase"
VITE_BACKEND=local

# ---- Option A: AWS (Amplify + Cognito) — recommended for production --------
# After you deploy the Amplify backend (see GO-LIVE.md), the Amplify CLI writes
# amplify_outputs.json into the project root. Set this to "aws" and that file is
# picked up automatically. Google + Apple sign-in are configured in the Amplify
# backend, not here.
# VITE_BACKEND=aws

# ---- Option B: Supabase (fastest alternative) -----------------------------
# Create a project at supabase.com, run supabase/schema.sql, set VITE_BACKEND=supabase.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---- Real bank / bills / investment connections ---------------------------
# These features call YOUR backend (AWS API/Lambda), which holds the provider
# secrets and talks to Basiq/Frollo (CDR), PayTo, SnapTrade/Sharesight, etc.
# Set this to your deployed API base URL. If blank, those features show as
# "needs backend" rather than pretending to be connected.
VITE_API_BASE=
